; Эхо: читает символ из порта 0xFFF1 и выводит в 0xFFF0
; Адреса команд рассчитаны для загрузки с 0x4000
10 1 240 255 0       ; 0x4000: MOV R1, 0xFFF0
10 2 241 255 0       ; 0x4005: MOV R2, 0xFFF1
26 0 241 255 0       ; 0x400A: LOAD R0, [0xFFF1]  (ввод)
30 0 240 255 0       ; 0x400F: STORE R0, [0xFFF0] (вывод)
22 0 10 64 0         ; 0x4014: JMP 0x400A
