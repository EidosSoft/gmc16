; Вывод цифр 0-9 с использованием JGE
10 0 48 0 0          ; R0 = '0'
10 1 240 255 0       ; R1 = порт вывода
10 2 57 0 0          ; R2 = '9'
10 3 1 0 0           ; R3 = 1
loop:
30 0 240 255 0       ; вывод символа
6 0 3 0 0            ; ADD R0, R3 (увеличить)
14 0 2 0 0           ; CMP R0, R2
25 0 26 64 0         ; JGE end (0x401A)
22 0 12 64 0         ; JMP loop (0x400C)
end:
31 0 0 0 0           ; HLT
